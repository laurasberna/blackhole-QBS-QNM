              RowBox[{"\[Gamma]", "[", "n", "]"}], 
              RowBox[{
               RowBox[{"\[Beta]", "[", "n", "]"}], "-", 
               RowBox[{
                RowBox[{"\[Alpha]", "[", "n", "]"}], "*", "Rn"}]}]]}], ";", 
            RowBox[{"n", "--"}], ";"}], "}"}]}], "\[IndentingNewLine]", "]"}],
         ";", "Rn"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{
     FractionBox[

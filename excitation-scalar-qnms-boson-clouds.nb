   RowBox[{"ae", "[", "1", "]"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"\[Beta]", "[", "0", "]"}]}], "/", 
     RowBox[{"\[Alpha]", "[", "0", "]"}]}], "/.", 
    RowBox[{"w", "\[Rule]", "root"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"i", "=", "1"}], ";", 
  RowBox[{"While", "[", 
   RowBox[{
    RowBox[{"i", "<", "N0"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"ae", "[", 
       RowBox[{"i", "+", "1"}], "]"}], "=", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"-", 
            RowBox[{"\[Beta]", "[", "i", "]"}]}], "*", 
           RowBox[{"ae", "[", "i", "]"}]}], "-", 
          RowBox[{
           RowBox[{"\[Gamma]", "[", "i", "]"}], "*", 
           RowBox[{"ae", "[", 
            RowBox[{"i", "-", "1"}], "]"}]}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"\[Alpha]", "[", "i", "]"}], ")"}]}], "/.", 
       RowBox[{"w", "\[Rule]", "root"}]}]}], ";", 
     RowBox[{"i", "=", 
      RowBox[{"i", "+", "1"}]}]}]}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.875860044729926*^9, 3.8758600750736866`*^9}},
 CellLabel->
  "In[109]:=",ExpressionUUID->"97700613-c05b-4b11-a1c7-d111f8f07f1d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"chi", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"mu0", "^", "2"}], "-", 
       RowBox[{"2", "*", 
        RowBox[{"w", "^", "2"}]}]}], ")"}], "/", "q"}], "/.", 
    RowBox[{"w", "->", "root"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sigma", "=", 
   RowBox[{
    RowBox[{"2", "*", "rplus", "*", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"w", "-", 
        RowBox[{"m0", "*", 
         RowBox[{"a0", "/", 
          RowBox[{"(", 
           RowBox[{"2", "*", "M", "*", "rplus"}], ")"}]}]}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"rplus", "-", "rminus"}], ")"}]}]}], "/.", 
    RowBox[{"w", "->", "root"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Rpsi", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{"I", " ", 
         RowBox[{"Pi", "/", "2"}]}], "]"}], 
       RowBox[{"(", 
        RowBox[{"r", "-", "rplus"}], ")"}]}], ")"}], "^", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "I"}], "*", "sigma"}], ")"}]}], 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "I"}], " ", 
        RowBox[{"Pi", "/", "2"}]}], ")"}], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "I"}], " ", "sigma"}], ")"}]}], "]"}], "*", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"r", "-", "rminus"}], ")"}], "^", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"I", "*", "sigma"}], "+", "chi", "-", "1"}], ")"}]}], "*", 
    RowBox[{"Exp", "[", 
     RowBox[{"q", "*", "r"}], "]"}], "*", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"ae", "[", "n", "]"}], "*", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"r", "-", "rplus"}], ")"}], "^", "n"}], "/", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"r", "-", "rminus"}], ")"}], "^", "n"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", "0", ",", "N0"}], "}"}]}], "]"}]}]}], 
  ";"}]}], "Input",

Cell[BoxData[
 RowBox[{
  RowBox[{"INT", "[", 
   RowBox[{
   "w_", ",", "mu_", ",", "ar_", ",", "l_", ",", "m_", ",", "s_", ",", 
    "NITMAX_", ",", " ", "sign_"}], "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"M", "=", "1"}], ";", "\[IndentingNewLine]", 
    RowBox[{"br", "=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"1", "-", 
       RowBox[{"ar", "^", "2"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"rminus", "=", 
     RowBox[{"(", 
      RowBox[{"1", "-", "br"}], ")"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"rplus", "=", 
     RowBox[{"1", "+", "br"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"k1", "=", 
     RowBox[{
      RowBox[{"1", "/", "2"}], "*", 
      RowBox[{"Abs", "[", 
       RowBox[{"m", "-", "s"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"k2", "=", 
     RowBox[{
      RowBox[{"1", "/", "2"}], "*", 
      RowBox[{"Abs", "[", 
       RowBox[{"m", "+", "s"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"OmegaH", "=", 
     RowBox[{"ar", "/", 
      RowBox[{"(", 
       RowBox[{"2", "*", "M", "*", "rplus"}], ")"}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"(*", "*****)"}], "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"\[Eta]", "=", 
       RowBox[{"Max", "[", 
        RowBox[{
         RowBox[{"Abs", "[", "m", "]"}], ",", 
         RowBox[{"Abs", "[", "s", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"\[Alpha]", "=", 
       RowBox[{"\[Eta]", "+", 
        RowBox[{"m", " ", 
         FractionBox["s", "\[Eta]"]}]}]}], ";", 
      RowBox[{"\[Beta]", "=", 
       RowBox[{"\[Eta]", "-", 
        RowBox[{"m", " ", 
         FractionBox["s", "\[Eta]"]}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"gino1", "=", 
       RowBox[{
        SuperscriptBox["z", "2"], "-", 
        RowBox[{
         FractionBox["1", "4"], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"\[Alpha]", "+", "\[Beta]"}], ")"}], "2"]}]}]}], ";", 
      RowBox[{"gino2", "=", 
       RowBox[{
        SuperscriptBox["z", "2"], "-", 
        RowBox[{
         FractionBox["1", "4"], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"\[Alpha]", "-", "\[Beta]"}], ")"}], "2"]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"h", "=", 
       FractionBox[
        RowBox[{"gino1", 
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox["z", "2"], "-", 
           SuperscriptBox["s", "2"]}], ")"}], " ", "gino2"}], 
        RowBox[{"2", 
         RowBox[{"(", 
          RowBox[{"z", "-", 
           RowBox[{"1", "/", "2"}]}], ")"}], 
         SuperscriptBox["z", "3"], 
         RowBox[{"(", 
          RowBox[{"z", "+", 
           RowBox[{"1", "/", "2"}]}], ")"}]}]]}], ";", "\[IndentingNewLine]", 
      
      RowBox[{"f0", "=", 
       RowBox[{
        RowBox[{"l", 
         RowBox[{"(", 
          RowBox[{"l", "+", "1"}], ")"}]}], "-", 
        RowBox[{"s", 
         RowBox[{"(", 
          RowBox[{"s", "+", "1"}], ")"}]}]}]}], ";", 
      RowBox[{"f1", "=", 
       RowBox[{
        RowBox[{"-", "2"}], " ", "m", " ", 
        FractionBox[
         SuperscriptBox["s", "2"], 
         RowBox[{"l", 
          RowBox[{"(", 
           RowBox[{"l", "+", "1"}], ")"}]}]]}]}], ";", 
      RowBox[{"f2", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"h", "/.", 
          RowBox[{"z", "\[Rule]", 
           RowBox[{"(", 
            RowBox[{"l", "+", "1"}], ")"}]}]}], ")"}], "-", 
        RowBox[{"(", 
         RowBox[{"h", "/.", 
          RowBox[{"z", "\[Rule]", "l"}]}], ")"}], "-", "1"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Alm", "=", 
       RowBox[{"f0", "+", 
        RowBox[{"f1", " ", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"ar", "^", "2"}], " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"w", "^", "2"}], "-", 
             RowBox[{"mu", "^", "2"}]}], ")"}]}], "]"}], "*", "0"}], "+", " ", 
        RowBox[{"f2", "*", 
         RowBox[{"ar", "^", "2"}], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"w", "^", "2"}], "-", 
           RowBox[{"mu", "^", "2"}]}], ")"}]}]}]}], ";"}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{"(*", "*****)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", "*****)"}], "\[IndentingNewLine]", 
    RowBox[{"Alm", "=", 
     RowBox[{
      RowBox[{"SpheroidalEigenvalue", "[", 
       RowBox[{"l", ",", "m", ",", 
        RowBox[{"I", " ", "ar", " ", 
         SqrtBox[
          RowBox[{
           SuperscriptBox["w", "2"], "-", 
           SuperscriptBox["mu", "2"]}]]}]}], "]"}], "-", 
      RowBox[{
       SuperscriptBox["ar", "2"], " ", 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["w", "2"], "-", 
         SuperscriptBox["mu", "2"]}], ")"}]}]}]}], ";", "\[IndentingNewLine]",
     "\[IndentingNewLine]", 
    RowBox[{"Clear", "[", 
     RowBox[{"\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]"}], "]"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"q", "=", 
     RowBox[{"sign", "*", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"mu", "^", "2"}], "-", 
        RowBox[{"w", "^", "2"}]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"c0", "=", 
     RowBox[{"1", "-", 
      RowBox[{"2", "*", "I", "*", "w"}], "-", 
      RowBox[{"2", "*", 
       RowBox[{"I", "/", "br"}], "*", 
       RowBox[{"(", 
        RowBox[{"w", "-", 
         RowBox[{"ar", "*", 
          RowBox[{"m", "/", "2"}]}]}], ")"}]}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"c1", "=", 
     RowBox[{
      RowBox[{"-", "4"}], "+", 
      RowBox[{"4", "*", "I", "*", 
       RowBox[{"(", 
        RowBox[{"w", "-", 
         RowBox[{"I", "*", "q", "*", 
          RowBox[{"(", 
           RowBox[{"1", "+", "br"}], ")"}]}]}], ")"}]}], "+", 
      RowBox[{"4", "*", 
       RowBox[{"I", "/", "br"}], "*", 
       RowBox[{"(", 
        RowBox[{"w", "-", 
         RowBox[{"ar", "*", 
          RowBox[{"m", "/", "2"}]}]}], ")"}]}], "-", 
      RowBox[{"2", "*", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"w", "^", "2"}], "+", 
          RowBox[{"q", "^", "2"}]}], ")"}], "/", "q"}]}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"c2", "=", 
     RowBox[{"3", "-", 
      RowBox[{"2", "*", "I", "*", "w"}], "-", 
      RowBox[{"2", "*", 
       RowBox[{"I", "/", "br"}], "*", 
       RowBox[{"(", 
        RowBox[{"w", "-", 
         RowBox[{"ar", "*", 
          RowBox[{"m", "/", "2"}]}]}], ")"}]}], "-", 
      RowBox[{"2", "*", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"q", "^", "2"}], "-", 
          RowBox[{"w", "^", "2"}]}], ")"}], "/", "q"}]}]}]}], ";", 
    RowBox[{"c3", "=", 
     RowBox[{
      RowBox[{"2", "*", "I", "*", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"w", "-", 
           RowBox[{"I", "*", "q"}]}], ")"}], "^", "3"}], "/", "q"}]}], "+", 
      RowBox[{"2", "*", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"w", "-", 
          RowBox[{"I", "*", "q"}]}], ")"}], "^", "2"}], "*", "br"}], "+", 
      RowBox[{
       RowBox[{"q", "^", "2"}], "*", 
       RowBox[{"ar", "^", "2"}]}], "+", 
      RowBox[{"2", "*", "I", "*", "q", "*", "ar", "*", "m"}], "-", "Alm", "-",
       "1", "-", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"w", "-", 
          RowBox[{"I", "*", "q"}]}], ")"}], "^", "2"}], "/", "q"}], "+", 
      RowBox[{"2", "*", "q", "*", "br"}], "+", 
      RowBox[{"2", "*", 
       RowBox[{"I", "/", "br"}], "*", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"w", "-", 
             RowBox[{"I", "*", "q"}]}], ")"}], "^", "2"}], "/", "q"}], "+", 
         "1"}], ")"}], "*", 
       RowBox[{"(", 
        RowBox[{"w", "-", 
         RowBox[{"ar", "*", 
          RowBox[{"m", "/", "2"}]}]}], ")"}]}]}]}], ";", 
    RowBox[{"c4", "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"w", "-", 
          RowBox[{"I", "*", "q"}]}], ")"}], "^", "4"}], "/", 
       RowBox[{"q", "^", "2"}]}], "+", 
      RowBox[{"2", "*", "I", "*", "w", "*", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"w", "-", 
           RowBox[{"I", "*", "q"}]}], ")"}], "^", "2"}], "/", "q"}]}], "-", 
      RowBox[{"2", "*", 
       RowBox[{"I", "/", "br"}], "*", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"w", "-", 
           RowBox[{"I", "*", "q"}]}], ")"}], "^", "2"}], "/", "q"}], "*", 
       RowBox[{"(", 
        RowBox[{"w", "-", 
         RowBox[{"ar", "*", 
          RowBox[{"m", "/", "2"}]}]}], ")"}]}]}]}], ";", 
    RowBox[{"\[Gamma]", "=", 
     RowBox[{"Function", "[", 
      RowBox[{"n", ",", 
       RowBox[{
        SuperscriptBox["n", "2"], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"c2", "-", "3"}], ")"}], "*", "n"}], "+", "c4", "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "c2"}], "+", "2"}], ")"}], "*", "0"}]}]}], "]"}]}], 
    ";", "\[IndentingNewLine]", 
    RowBox[{"\[Beta]", "=", 
     RowBox[{"Function", "[", 
      RowBox[{"n", ",", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "2"}], "*", 
         RowBox[{"n", "^", "2"}]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"c1", "+", "2"}], ")"}], "*", "n"}], "+", "c3"}]}], "]"}]}],
     ";", "\[IndentingNewLine]", 
    RowBox[{"\[Alpha]", "=", 
     RowBox[{"Function", "[", 
      RowBox[{"n", ",", 
       RowBox[{
        SuperscriptBox["n", "2"], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"c0", "+", "1"}], ")"}], "*", "n"}], "+", "c0"}]}], "]"}]}],
     ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"Leaver31", "=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "Rn", "}"}], ",", 
       RowBox[{
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"{", 

Cell[BoxData[
 RowBox[{
  RowBox[{"OverlapInterpBoundaryofM", "[", 
   RowBox[{
   "yp_", ",", "ye_", ",", "\[Omega]p_", ",", "\[Omega]e_", ",", "regul_", 
    ",", "rinf_", ",", "l_", ",", " ", "R_", ",", "  ", 
    RowBox[{"M_", "?", "NumericQ"}]}], "]"}], ":=", 
  RowBox[{"NIntegrate", "[", 
   RowBox[{
    RowBox[{"Rationalize", "[", 
     RowBox[{
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "-", 
          FractionBox[
           RowBox[{"2", "M"}], "r"]}], ")"}], 
        RowBox[{"-", "1"}]], 
       FractionBox[
        RowBox[{"r", "^", "l"}], 
        RowBox[{
         RowBox[{"R", "^", 
          RowBox[{"(", 
           RowBox[{"l", "+", "1"}], ")"}]}], 
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"r", "/", "R"}], ")"}], "^", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"2", "l"}], "+", "1"}], ")"}]}]}], ")"}]}]], 

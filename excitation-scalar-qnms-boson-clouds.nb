            RowBox[{"n", "=", "NITMAX"}], ";", 
            RowBox[{"Rn", "=", 
             RowBox[{"-", "1.0"}]}], ";"}], "}"}], ",", 
          RowBox[{"n", ">", "0"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Rn", "=", 

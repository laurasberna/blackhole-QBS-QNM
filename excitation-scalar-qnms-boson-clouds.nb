Cell["normalization factor for QBS", "Subsubsection",
 CellChangeTimes->{{3.9301304132864237`*^9, 
  3.930130422483862*^9}},ExpressionUUID->"409bdfe4-bcb2-4167-850d-\
2bd0d14ae32e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"OverlapInterpBoundaryofM", "[", 
   RowBox[{
   "yp_", ",", "ye_", ",", "\[Omega]p_", ",", "\[Omega]e_", ",", "regul_", 
    ",", "rinf_", ",", " ", 
    RowBox[{"M_", "?", "NumericQ"}]}], "]"}], ":=", 
  RowBox[{
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{"Rationalize", "[", 
      RowBox[{
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "-", 
           FractionBox[
            RowBox[{"2", "M"}], "r"]}], ")"}], 
         RowBox[{"-", "1"}]], 
        RowBox[{"(", "ye", ")"}], 
        RowBox[{"(", "yp", ")"}]}], " ", ",", "0"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", 
       RowBox[{"2", "M", 
        RowBox[{"(", 
         RowBox[{"1", "+", "regul"}], ")"}]}], ",", "10000"}], "}"}], ",", 
     RowBox[{"AccuracyGoal", "\[Rule]", "30"}], ",", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"PrecisionGoal", "\[Rule]", "8"}], ","}], "*)"}], " ", 
     RowBox[{"Method", "\[Rule]", "\"\<LocalAdaptive\>\""}]}], "]"}], "+", 
   RowBox[{"Rationalize", "[", 
    RowBox[{
     RowBox[{
      FractionBox["\[ImaginaryI]", 
       RowBox[{"(", 
        RowBox[{"\[Omega]p", "+", "\[Omega]e"}], ")"}]], 
      RowBox[{"(", 
       RowBox[{"ye", "/.", 
        RowBox[{"r", "\[Rule]", " ", 
         RowBox[{"(", 
          RowBox[{"2", "M", 
           RowBox[{"(", 
            RowBox[{"1", "+", "regul"}], ")"}]}], ")"}]}]}], ")"}], 
      RowBox[{"(", 
       RowBox[{"yp", "/.", 
        RowBox[{"r", "\[Rule]", " ", 
         RowBox[{"(", 
          RowBox[{"2", "M", 
           RowBox[{"(", 
            RowBox[{"1", "+", "regul"}], ")"}]}], ")"}]}]}], ")"}]}], " ", 
     ",", "0"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.878387158159363*^9, 3.878387166020006*^9}, {
  3.87838721359135*^9, 3.8783872142938547`*^9}, {3.878387258431985*^9, 

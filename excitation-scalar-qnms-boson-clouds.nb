Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Fapprox", "[", 
    RowBox[{"r_", ",", " ", "R_", ",", " ", "l_"}], "]"}], ":=", " ", 
   FractionBox[
    RowBox[{"r", "^", "l"}], 
    RowBox[{
     RowBox[{"R", "^", 
      RowBox[{"(", 
       RowBox[{"l", "+", "1"}], ")"}]}], 
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"r", "/", "R"}], ")"}], "^", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", "l"}], "+", "1"}], ")"}]}]}], ")"}]}]]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"F", "[", 
    RowBox[{"r_", ",", " ", "R_", ",", " ", "l_"}], "]"}], ":=", " ", 
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{"r", "^", "l"}], 
      RowBox[{"R", "^", 
       RowBox[{"(", 
        RowBox[{"l", "+", "1"}], ")"}]}]], 
     RowBox[{"HeavisideTheta", "[", 
      RowBox[{"R", "-", "r"}], "]"}]}], "+", 
    RowBox[{
     FractionBox[
      RowBox[{"R", "^", "l"}], 
      RowBox[{"r", "^", 
       RowBox[{"(", 
        RowBox[{"l", "+", "1"}], ")"}]}]], 
     RowBox[{"HeavisideTheta", "[", 
      RowBox[{"r", "-", "R"}], "]"}]}]}]}], 
  ";"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.965809074756542*^9, 3.9658091549530277`*^9}},
 CellLabel->"In[81]:=",ExpressionUUID->"bafce390-314b-4fd5-80a1-cb941f73dd8a"],

